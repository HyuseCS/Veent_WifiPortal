# ─────────────────────────────────────────────────────────────────────────────────────────
# Production env for compose.prod.yaml. Copy to `.env` (same dir) and fill real values:
#     cp .env.prod.example .env
# Aggregates the per-app apps/*/.env.example vars for the single-VM stack. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────────────────

# ── Postgres (db service) ──────────────────────────────────────────────────────────────────
POSTGRES_USER="radius"
POSTGRES_PASSWORD="CHANGE_ME_strong_db_password"
POSTGRES_DB="radius"
# Shared connection string — hostname is the compose service name `db`. Must match the trio above.
DATABASE_URL="postgres://radius:CHANGE_ME_strong_db_password@db:5432/radius"

# ── Public origins (per app — the LAN URL each app is browsed on) ───────────────────────────
# On a NAT'd LAN deploy these are http LAN addresses (e.g. http://10.5.50.1:3001). Behind a TLS
# reverse proxy, use https://<domain>. customer 3001 / admin 3002 / locator 3003.
CUSTOMER_ORIGIN="http://LAN_IP:3001"
ADMIN_ORIGIN="http://LAN_IP:3002"
LOCATOR_ORIGIN="http://LAN_IP:3003"
# Public https tunnel origin for the customer Maya round-trip (its ngrok/relay URL). REQUIRED for
# Maya checkouts on a NAT'd site; leave blank only if the portal origin is publicly reachable.
TUNNEL_ORIGIN=""

# ── Better Auth secrets (DISTINCT per app — never share the customer/admin secret) ──────────
# Generate each: `openssl rand -base64 32`. 32+ chars; admin enforces the length at boot.
CUSTOMER_BETTER_AUTH_SECRET="CHANGE_ME_customer_32plus_char_secret"
ADMIN_BETTER_AUTH_SECRET="CHANGE_ME_admin_32plus_char_secret"

# ── Cron secrets (customer + admin have SEPARATE secrets; the cron sidecar uses both) ───────
CUSTOMER_CRON_SECRET="CHANGE_ME_customer_cron_secret"
ADMIN_CRON_SECRET="CHANGE_ME_admin_cron_secret"

# ── Network controller (admin + customer) ──────────────────────────────────────────────────
# "mikrotik" in prod. MIKROTIK_HOST = the router's LAN IP reachable from this VM over api-ssl.
NETWORK_CONTROLLER="mikrotik"
MIKROTIK_HOST="10.210.0.1"
MIKROTIK_USER=""
MIKROTIK_PASSWORD=""
MIKROTIK_PORT="8728"
MIKROTIK_TLS="false"
MIKROTIK_TLS_INSECURE="false"
MIKROTIK_HOTSPOT_USER=""
MIKROTIK_HOTSPOT_PASSWORD=""
HEALTH_EXCLUDE_INTERFACES=""
# WireGuard isolation is NOT used in this deploy (VM is on the router LAN) — leave blank.
ADMIN_WG_HOSTS=""
ADMIN_WG_IPS=""
# Optional source-IP allowlist for customer cron endpoints (revoke/reconcile).
CRON_IP_ALLOWLIST=""

# ── Maya payments (customer) ────────────────────────────────────────────────────────────────
MAYA_PUBLIC_KEY=""
MAYA_SECRET_KEY=""
MAYA_SANDBOX="false"

# ── SMS OTP (customer) — pick provider; fill only that provider's config ────────────────────
SMS_PROVIDER="cast"
CAST_API_KEY=""
CAST_SENDER_ID=""
ITEXMO_API_CODE=""
ITEXMO_EMAIL=""
ITEXMO_PASSWORD=""
ITEXMO_SENDER_ID=""
UNISMS_SECRET_KEY=""
UNISMS_SENDER_ID=""
SMSGATE_BASE_URL=""
SMSGATE_USERNAME=""
SMSGATE_PASSWORD=""

# ── Resend email (admin — staff invites / wipe codes). Blank falls back to the console stub. ─
RESEND_API_KEY=""
EMAIL_FROM="RADIUS <noreply@veent.io>"

# ── First-owner bootstrap (admin — used only by `bootstrap:owner`, run manually once) ───────
OWNER_EMAIL=""
OWNER_PASSWORD=""
OWNER_NAME="Owner"

# ── Sentry (all optional; leave unset to disable telemetry). SENTRY_AUTH_TOKEN is the /sentry
#    dashboard token — the build-time source-map token is separate and never needed at runtime. ─
PUBLIC_SENTRY_DSN=""
PUBLIC_SENTRY_ENVIRONMENT="production"
SENTRY_ENVIRONMENT="production"
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=""
SENTRY_TRACES_SAMPLE_RATE=""
PUBLIC_SENTRY_RELEASE=""
SENTRY_RELEASE=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG_SLUG=""
SENTRY_PROJECT_ID=""

{
	"name": "veent-wifiportal",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"dev:customer": "bun run --filter veent-customer dev",
		"dev:admin": "bun run --filter veent-admin dev",
		"build": "bun run --filter './apps/*' build",
		"check": "bun run --filter './apps/*' check",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "bun run --filter './apps/*' test",
		"db:start": "docker compose up",
		"db:push": "bun run --filter @veent/db db:push",
		"db:generate": "bun run --filter @veent/db db:generate",
		"db:migrate": "bun run --filter @veent/db db:migrate",
		"db:studio": "bun run --filter @veent/db db:studio",
		"db:seed": "bun run --filter @veent/db db:seed"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1"
	}
}

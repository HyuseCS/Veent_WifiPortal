# Shared database (same DATABASE_URL across all modules)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Public origin of THIS app (the customer captive portal). e.g. https://portal.veent.io
ORIGIN="http://localhost:5173"

# Client-IP resolution for the per-IP rate limiters (adapter-node `getClientAddress()`).
# Leave BOTH unset when the app terminates connections directly (default) — the limiter then
# keys on the real TCP peer and CANNOT be spoofed via headers.
# ONLY set these when a trusted reverse proxy sits in front:
#   ADDRESS_HEADER=x-forwarded-for   # the header the proxy appends the client IP to
#   XFF_DEPTH=1                       # number of trusted proxy hops (count YOUR proxies)
# Getting XFF_DEPTH wrong (or setting ADDRESS_HEADER without a proxy) makes the client IP
# SPOOFABLE — an attacker rotates the header to evade per-IP throttles. Setting nothing behind
# a proxy collapses every request to the proxy IP (one shared bucket → lockout DoS). See
# SECURITY_RISKS R-rate-limit / the adapter-node docs.
# ADDRESS_HEADER=""
# XFF_DEPTH=""

# Better Auth — per-app secret. Use 32+ high-entropy chars in production.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Network controller (firewall grant/revoke): "stub" | "mikrotik".
NETWORK_CONTROLLER="stub"
# MikroTik RouterOS binary API (used when NETWORK_CONTROLLER=mikrotik).
MIKROTIK_HOST=""
MIKROTIK_USER=""
MIKROTIK_PASSWORD=""
MIKROTIK_PORT="8728"
MIKROTIK_TLS="false"
MIKROTIK_TLS_INSECURE="false"
# Proactive hotspot activation (Issue 2 — clears the OS captive "Sign in to network" screen
# right after a grant). Runs over the binary API above (RouterOS v6 has no REST). Setting
# MIKROTIK_HOTSPOT_USER OPTS IN: it must name a real hotspot user on the guest profile (e.g. a
# shared `veent-guest`). Leave blank to disable activation (grant/revoke still work; the banner
# just clears a little slower). See docs/mikrotik/hotspot-activation.md.
MIKROTIK_HOTSPOT_USER=""
MIKROTIK_HOTSPOT_PASSWORD=""

# Shared secret for the cron-callable POST /api/network/revoke (x-cron-secret header).
CRON_SECRET=""
# Optional comma-separated source-IP allowlist for the cron endpoints (revoke, reconcile).
# When set, only these IPs may call them (in addition to CRON_SECRET); unset = no IP check.
CRON_IP_ALLOWLIST=""

# Maya (PayMaya) payment gateway.
MAYA_PUBLIC_KEY=""
MAYA_SECRET_KEY=""
# "true" = sandbox host, "false" = production.
MAYA_SANDBOX="true"

# iTexMo SMS gateway (OTP delivery). All three required to send; without them dev
# prints the OTP to the server console and production refuses the OTP flow. From the
# iTexMo dashboard (itexmo.com).
ITEXMO_API_CODE=""
ITEXMO_EMAIL=""
ITEXMO_PASSWORD=""
# Optional approved sender id. On a TRIAL account this MUST be "ITM.TEST3"; omit to
# use the account default.
ITEXMO_SENDER_ID=""

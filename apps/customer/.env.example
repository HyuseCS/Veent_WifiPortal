# Shared database (same DATABASE_URL across all modules)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Public origin of THIS app (the customer captive portal). e.g. https://portal.veent.io
# In a NAT'd hotspot deploy this is the LAN address guests browse on (setup:prod sets it to the
# device LAN IP) — see TUNNEL_ORIGIN below for the PUBLIC address used for the Maya round-trip.
ORIGIN="http://localhost:5173"

# Public https tunnel origin for THIS site (its ngrok URL), e.g. https://abc123.ngrok-free.app.
# Two uses: (1) the metadata.originUrl the central Veent DO relay forwards the payment webhook back
# to (${TUNNEL_ORIGIN}/api/webhooks/maya/payment-status) — ALWAYS uses this; (2) a FALLBACK for the
# Maya buyer redirect URLs, used only when the buyer's own origin isn't publicly reachable (the prod
# captive portal served on a LAN IP). A localhost dev session or a public-domain deploy redirects
# back to where the buyer started, not here. REQUIRED for Maya checkouts on a NAT'd site: Maya
# rejects http/private-IP URLs and the DO can't reach a LAN address. Left blank on a NAT'd site →
# those URLs go out blank and Maya/the DO reject the checkout (fail loudly, no silent LAN fallback).
# Bare origin, no path. Rotates with the tunnel.
TUNNEL_ORIGIN=""

# Client-IP resolution for the per-IP rate limiters (adapter-node `getClientAddress()`).
# Leave BOTH unset when the app terminates connections directly (default) — the limiter then
# keys on the real TCP peer and CANNOT be spoofed via headers.
# ONLY set these when a trusted reverse proxy sits in front:
#   ADDRESS_HEADER=x-forwarded-for   # the header the proxy appends the client IP to
#   XFF_DEPTH=1                       # number of trusted proxy hops (count YOUR proxies)
# Getting XFF_DEPTH wrong (or setting ADDRESS_HEADER without a proxy) makes the client IP
# SPOOFABLE — an attacker rotates the header to evade per-IP throttles. Setting nothing behind
# a proxy collapses every request to the proxy IP (one shared bucket → lockout DoS). See
# SECURITY_RISKS R-rate-limit / the adapter-node docs.
# ADDRESS_HEADER=""
# XFF_DEPTH=""

# Better Auth — per-app secret. Use 32+ high-entropy chars in production.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Network controller (firewall grant/revoke): "stub" | "mikrotik".
NETWORK_CONTROLLER="stub"
# MikroTik RouterOS binary API (used when NETWORK_CONTROLLER=mikrotik).
MIKROTIK_HOST=""
MIKROTIK_USER=""
MIKROTIK_PASSWORD=""
MIKROTIK_PORT="8728"
MIKROTIK_TLS="false"
MIKROTIK_TLS_INSECURE="false"
# Proactive hotspot activation (Issue 2 — clears the OS captive "Sign in to network" screen
# right after a grant). Runs over the binary API above (RouterOS v6 has no REST). Setting
# MIKROTIK_HOTSPOT_USER OPTS IN: it must name a real hotspot user on the guest profile (e.g. a
# shared `veent-guest`). Leave blank to disable activation (grant/revoke still work; the banner
# just clears a little slower). See docs/mikrotik/hotspot-activation.md.
MIKROTIK_HOTSPOT_USER=""
MIKROTIK_HOTSPOT_PASSWORD=""

# Shared secret for the cron-callable POST /api/network/revoke (x-cron-secret header).
CRON_SECRET=""
# Optional comma-separated source-IP allowlist for the cron endpoints (revoke, reconcile).
# When set, only these IPs may call them (in addition to CRON_SECRET); unset = no IP check.
CRON_IP_ALLOWLIST=""

# Maya (PayMaya) payment gateway.
MAYA_PUBLIC_KEY=""
MAYA_SECRET_KEY=""
# "true" = sandbox host, "false" = production.
MAYA_SANDBOX="true"

# SMS OTP delivery. Which gateway sends the login codes: "itexmo" (default) or "unisms".
# Only the SELECTED provider's config below is used; missing config for it → dev prints the
# OTP to the server console, production refuses the OTP flow.
SMS_PROVIDER="itexmo"

# --- iTexMo (itexmo.com) — used when SMS_PROVIDER=itexmo. First three required to send. ---
ITEXMO_API_CODE=""
ITEXMO_EMAIL=""
ITEXMO_PASSWORD=""
# Optional approved sender id. On a TRIAL account this MUST be "ITM.TEST3"; omit to
# use the account default.
ITEXMO_SENDER_ID=""

# --- UniSMS (unismsapi.com) — used when SMS_PROVIDER=unisms. BOTH required to send. ---
# API secret key (sk_…) — used as the Basic-auth username with an empty password.
UNISMS_SECRET_KEY=""
# Sender id — UniSMS requires one on every message (a random test id at first; apply for a real one).
UNISMS_SENDER_ID=""

# --- Sentry (all optional — leave every var unset to disable telemetry entirely) ---
# Left COMMENTED OUT so they are genuinely unset: an assigned "" would ship a blank
# environment/release and Number("") → 0 (tracing silently off), defeating the code's
# fallbacks. Uncomment and fill in only when you actually want telemetry.
# Error + performance ingestion (browser AND server). Public by design. From Sentry:
# Settings → Projects → <project> → Client Keys (DSN).
#PUBLIC_SENTRY_DSN=
# Environment tag on events. The server prefers SENTRY_ENVIRONMENT; both default to
# development/production when unset.
#PUBLIC_SENTRY_ENVIRONMENT=
#SENTRY_ENVIRONMENT=
# Fraction of requests traced for performance in production (0–1). Default 0.2.
# PUBLIC_ is read by the browser, the unprefixed one by the server.
#PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
#SENTRY_TRACES_SAMPLE_RATE=
# Deploy identifier (e.g. git SHA) to tie errors to a release. Set BOTH to the same value.
#PUBLIC_SENTRY_RELEASE=
#SENTRY_RELEASE=

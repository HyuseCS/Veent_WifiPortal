# Shared database (same DATABASE_URL across all modules)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Public origin of THIS app (the customer captive portal). e.g. https://portal.veent.io
ORIGIN="http://localhost:5173"

# Better Auth — per-app secret. Use 32+ high-entropy chars in production.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Network controller (firewall grant/revoke): "stub" | "mikrotik".
NETWORK_CONTROLLER="stub"

# Shared secret for the cron-callable POST /api/network/revoke (x-cron-secret header).
CRON_SECRET=""

# Maya (PayMaya) payment gateway. 
MAYA_PUBLIC_KEY=""
MAYA_SECRET_KEY=""
# "true" = sandbox host, "false" = production.
MAYA_SANDBOX="true"

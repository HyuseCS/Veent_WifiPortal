		"leaflet": "^1.9.4"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/leaflet": "^1.9.20",
		"@types/node": "^20",
		"@vitest/browser-playwright": "^4.1.8",
		"playwright": "^1.60.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",

# Shared database (same DATABASE_URL across all modules)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Public origin of THIS app (the Radius locator map). e.g. https://radius.veent.io
ORIGIN="http://localhost:5172"

# --- Sentry (all optional — leave every var unset to disable telemetry entirely) ---
# Left COMMENTED OUT so they are genuinely unset: an assigned "" would ship a blank
# environment/release and Number("") → 0 (tracing silently off), defeating the code's
# fallbacks. Uncomment and fill in only when you actually want telemetry.
# Error + performance ingestion (browser AND server). Public by design. From Sentry:
# Settings → Projects → <project> → Client Keys (DSN). The same DSN as the other apps is
# fine — events are separated by the `app: locator` tag.
#PUBLIC_SENTRY_DSN=
# Environment tag on events. The server prefers SENTRY_ENVIRONMENT; both default to
# development/production when unset.
#PUBLIC_SENTRY_ENVIRONMENT=
#SENTRY_ENVIRONMENT=
# Fraction of requests traced for performance in production (0–1). Default 0.2.
# PUBLIC_ is read by the browser, the unprefixed one by the server.
#PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
#SENTRY_TRACES_SAMPLE_RATE=
# Deploy identifier (e.g. git SHA) to tie errors to a release. Set BOTH to the same value.
#PUBLIC_SENTRY_RELEASE=
#SENTRY_RELEASE=

# Shared database (same DATABASE_URL across all modules)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Public origin of THIS app (the admin dashboard). e.g. https://admin.veent.io
ORIGIN="http://localhost:5174"

# Better Auth — per-app secret, DISTINCT from the customer app. 32+ chars in prod.
BETTER_AUTH_SECRET=""

# Network controller (for block/kick). Only "stub" exists today. Match the
# customer app's value in production so both talk to the same controller.
NETWORK_CONTROLLER="stub"

# First-owner bootstrap (used only by `bun run bootstrap:owner`). Public admin
# self-registration is disabled — the owner is seeded here, everyone else is invited.
OWNER_EMAIL=""
OWNER_PASSWORD=""
OWNER_NAME="Owner"

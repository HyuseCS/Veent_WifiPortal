# Shared database (same DATABASE_URL across all modules)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5433/local"

# Public origin of THIS app (the admin dashboard). In production the admin app is
# served ON THE LAN (no external hosting) so staff reach it from any device on the
# WiFi — set ORIGIN to its LAN address, e.g. http://10.5.50.1:5174 or
# http://admin.veent.lan. `bun run setup:router` whitelists this host in the
# hotspot walled garden so it's reachable BEFORE a device authenticates.
ORIGIN="http://localhost:5174"

# Client-IP resolution for the per-IP rate limiters (admin login, etc.) via adapter-node
# `getClientAddress()`. Leave BOTH unset when the app terminates connections directly (default,
# and the LAN deploy above) — the limiter keys on the real TCP peer and CANNOT be header-spoofed.
# ONLY set these when a trusted reverse proxy fronts the app:
#   ADDRESS_HEADER=x-forwarded-for   # header the proxy appends the client IP to
#   XFF_DEPTH=1                       # number of trusted proxy hops (count YOUR proxies)
# Wrong XFF_DEPTH (or ADDRESS_HEADER with no proxy) makes the client IP SPOOFABLE → per-IP
# throttles bypassable; nothing-behind-a-proxy collapses all requests to one bucket → lockout
# DoS. See SECURITY_RISKS R-rate-limit.
# ADDRESS_HEADER=""
# XFF_DEPTH=""

# Better Auth — per-app secret, DISTINCT from the customer app. 32+ chars in prod.
BETTER_AUTH_SECRET=""

# Network controller (for block/kick): "stub" | "mikrotik". Match the customer
# app's value in production so both talk to the same controller.
NETWORK_CONTROLLER="stub"

# MikroTik RouterOS API (used when NETWORK_CONTROLLER=mikrotik).
MIKROTIK_HOST=""
MIKROTIK_USER=""
MIKROTIK_PASSWORD=""
MIKROTIK_PORT="8728"
MIKROTIK_TLS="false"
MIKROTIK_TLS_INSECURE="false"
# Proactive hotspot activation (Issue 2 — clears the OS captive "Sign in to network" screen
# right after a grant). Runs over the binary API above (RouterOS v6 has no REST). Setting
# MIKROTIK_HOTSPOT_USER OPTS IN: it must name a real hotspot user on the guest profile (e.g. a
# shared `veent-guest`). Leave blank to disable activation (grant/revoke still work). See
# docs/mikrotik/hotspot-activation.md.
MIKROTIK_HOTSPOT_USER=""
MIKROTIK_HOTSPOT_PASSWORD=""
# Comma-separated router interfaces to hide from the Networks view / map even if a
# hotspot binds them (e.g. a wired/management `ether2` that isn't a guest AP).
HEALTH_EXCLUDE_INTERFACES=""
# Walled-garden provisioning (`bun run setup:router`). The admin host derived from
# ORIGIN is whitelisted automatically; add any extra hosts/IPs here (comma-separated).
ADMIN_WG_HOSTS=""
ADMIN_WG_IPS=""
# Shared secret for cron-callable endpoints (POST /api/network/health/refresh).
# Required in the `x-cron-secret` header; leave blank to disable those endpoints.
CRON_SECRET=""
# Resend transactional email (staff activation invites). Server-only secret —
# never expose to the client, never prefix PUBLIC_. Leave BLANK in dev to use the
# console stub. Create a key scoped to "Sending access" only and rotate on leak.
RESEND_API_KEY=""
# Verified Resend sender. The domain MUST have SPF + DKIM + DMARC configured in
# Resend (anti-spoofing / deliverability). Format: "RADIUS <noreply@yourdomain>".
EMAIL_FROM="RADIUS <noreply@veent.io>"

# First-owner bootstrap (used only by `bun run bootstrap:owner`). Public admin
# self-registration is disabled — the owner is seeded here, everyone else is invited.
OWNER_EMAIL=""
OWNER_PASSWORD=""
OWNER_NAME="Owner"

# --- Sentry (all optional — leave every var unset to disable telemetry entirely) ---
# Error + performance ingestion (browser AND server). Public by design. From Sentry:
# Settings → Projects → <project> → Client Keys (DSN).
PUBLIC_SENTRY_DSN=""
# Environment tag on events. The server prefers SENTRY_ENVIRONMENT; both default to
# development/production when unset.
PUBLIC_SENTRY_ENVIRONMENT=""
SENTRY_ENVIRONMENT=""
# Fraction of requests traced for performance in production (0–1). Default 0.2.
# PUBLIC_ is read by the browser, the unprefixed one by the server.
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=""
SENTRY_TRACES_SAMPLE_RATE=""
# Deploy identifier (e.g. git SHA) to tie errors to a release. Set BOTH to the same value.
PUBLIC_SENTRY_RELEASE=""
SENTRY_RELEASE=""
# /sentry dashboard API access (admin only). SERVER-ONLY SECRET — never expose to the
# client, never prefix PUBLIC_, never log. Token scopes: event:read + event:write + org:read.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG_SLUG=""
SENTRY_PROJECT_ID=""
# API region base. Default https://de.sentry.io/api/0 (this org lives in Sentry's DE region);
# override only for another region or self-hosted Sentry.
# SENTRY_API_BASE=""

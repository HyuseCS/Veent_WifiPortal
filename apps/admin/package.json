{
	"name": "radius-admin",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5174",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"bootstrap:owner": "bun run scripts/bootstrap-owner.ts",
		"setup:router": "bun run scripts/setup-router.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output ../../packages/db/src/schema/auth-admin.generated.ts --yes"
	},
	"dependencies": {
		"@veent/core": "workspace:*",
		"@veent/db": "workspace:*",
		"better-auth": "~1.4.21",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^1.0.1",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^20",
		"@vitest/browser-playwright": "^4.1.8",
		"playwright": "^1.60.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	}
}
